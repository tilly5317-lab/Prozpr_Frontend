# Copy to `.env` in this folder.

# --- Option C: direct API from browser (`npm run dev` or `npm run build`) ---
# Set this to your backend origin (no trailing slash). Requests go to
#   {VITE_API_BASE_URL}/api/v1/...
# and do NOT use the Vite proxy. Backend ALLOWED_ORIGINS must include your UI origin,
# e.g. http://localhost:8080 (this repo’s Vite port) or your deployed UI URL.
VITE_API_BASE_URL=http://43.205.235.185

# Leave empty to use same-origin `/api/v1` + Vite dev proxy (API_DEV_PROXY below).

# --- Dev proxy (only when VITE_API_BASE_URL is empty) ---
# API_DEV_PROXY=http://127.0.0.1:8000

# Optional UI-only / stub flows (see `vite-env.d.ts`).
VITE_FRONTEND_ONLY=

# --- PostHog product analytics (optional; leave KEY empty to disable) ---
# Project API key from PostHog → Settings → Project. Public, safe to ship in the bundle.
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Prozpr team Zoom call ---
# Standing Zoom room used by "Talk to the Prozpr team" (portfolio card) and the
# advisor-meetings page. Leave empty to use a placeholder zoom.us link.
VITE_PROZPR_ZOOM_URL=

# CI/CD note:
# Docker production builds must provide VITE_API_BASE_URL as a build arg/environment
# (for GitHub Actions: repository Variable or Secret named VITE_API_BASE_URL).
