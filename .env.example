# Copy to `.env` in this folder. Vite only exposes variables prefixed with `VITE_`.

# Optional: backend origin for API calls (no trailing slash).
# Leave empty to use relative `/api/v1` — matches `vite.config.ts` dev proxy to localhost:8000.
# Set for production or when calling the API without a reverse proxy, e.g.:
# VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=

# Set to `1` or `true` to run UI-only / stub flows where supported (see `vite-env.d.ts`).
VITE_FRONTEND_ONLY=
