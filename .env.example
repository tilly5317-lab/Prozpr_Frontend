# Copy to `.env` in this folder.

# --- Production / absolute API (`npm run build` and optionally `npm run dev`) ---
# Browser calls: {VITE_API_BASE_URL}/api/v1/...  (no trailing slash on the base).
# Use your public API host, e.g. EC2:
VITE_API_BASE_URL=http://43.205.235.185
#
# Leave empty only if the UI is served from the same host that serves `/api/v1`
# (e.g. nginx reverse proxy), or you rely solely on the dev proxy below.

# --- Dev server only (`npm run dev`) ---
# When VITE_API_BASE_URL is empty, Vite forwards /api/v1 here. Not sent to the browser.
# API_DEV_PROXY=http://43.205.235.185

# Optional UI-only / stub flows (see `vite-env.d.ts`).
VITE_FRONTEND_ONLY=
